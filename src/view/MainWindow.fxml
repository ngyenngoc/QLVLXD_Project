                        <Button fx:id="btnSettings" alignment="BASELINE_LEFT" graphicTextGap="15.0" mnemonicParsing="false" prefHeight="55.0" prefWidth="260.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;" text="Cài đặt">
                            <graphic>
                                <ImageView fitHeight="24.0" fitWidth="24.0" pickOnBounds="true" preserveRatio="true">
                                    <image>
                                        <Image url="@image/caidat.png" />
