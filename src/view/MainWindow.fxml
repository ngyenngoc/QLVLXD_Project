                            <padding><Insets left="30.0" /></padding>
                        </Button>

                        <Button fx:id="btnSupplier" alignment="BASELINE_LEFT" graphicTextGap="15.0" mnemonicParsing="false" onAction="#handleShowSupplier" prefHeight="55.0" prefWidth="260.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;" text="Nhà cung cấp">
