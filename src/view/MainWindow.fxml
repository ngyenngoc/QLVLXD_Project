                <StackPane fx:id="centerContent" prefHeight="150.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
                    <padding>
                        <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
                    </padding>
                </StackPane>
            </children>
