                <HBox alignment="CENTER_LEFT" prefHeight="80.0" prefWidth="1020.0" style="-fx-background-color: white; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                    <children>
                        <ImageView fitHeight="24.0" fitWidth="24.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@image/tongquan.png" />
                            </image>
                        </ImageView>
                        <Label fx:id="lblTitle" prefHeight="27.0" prefWidth="285.0" text=" Hệ thống quản lý VLXD" textFill="#2c3e50">
                            <font><Font name="System Bold" size="18.0" /></font>
                        </Label>

                        <Pane prefHeight="43.0" prefWidth="654.0" HBox.hgrow="ALWAYS" />

                        <HBox alignment="CENTER" spacing="10.0">
                            <children>
                                <VBox alignment="CENTER_RIGHT" prefHeight="80.0">
