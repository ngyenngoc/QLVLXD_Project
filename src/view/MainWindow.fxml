                                            <font><Font size="14.0" /></font>
                                            <padding><Insets left="55.0" /></padding>
                                        </Button>

                                        <Button fx:id="btnCategory" alignment="BASELINE_LEFT" graphicTextGap="15.0" mnemonicParsing="false" onAction="#handleShowCategory" prefHeight="45.0" prefWidth="260.0" style="-fx-background-color: transparent; -fx-text-fill: #d1d1d1; -fx-cursor: hand;" text="• Loại vật liệu">
                                            <font><Font size="14.0" /></font>
                                            <padding><Insets left="55.0" /></padding>
                                        </Button>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                        <Button fx:id="btnCustomer" alignment="BASELINE_LEFT" graphicTextGap="15.0" mnemonicParsing="false" onAction="#handleShowCustomer" prefHeight="55.0" prefWidth="260.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;" text="Khách hàng">
                            <graphic>
                                <ImageView fitHeight="13.0" fitWidth="26.0" pickOnBounds="true" preserveRatio="true">
