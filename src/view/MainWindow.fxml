                                    </image>
                                </ImageView>
                            </graphic>
                            <font><Font name="System Bold" size="15.0" /></font>
                            <padding><Insets left="30.0" /></padding>
                        </Button>

                        <VBox spacing="0.0">
                            <children>
                                <Button fx:id="btnMaterialGroup" alignment="BASELINE_LEFT" graphicTextGap="15.0" mnemonicParsing="false" onAction="#toggleMaterialMenu" prefHeight="55.0" prefWidth="260.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand; -fx-border-color: transparent transparent transparent #f97316; -fx-border-width: 0 0 0 5;" text="Vật liệu">
