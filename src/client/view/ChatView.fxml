<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="550" prefWidth="450" spacing="10" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.controller.ChatController">

    <padding>
        <Insets bottom="10" left="10" right="10" top="10" />
    </padding>

    <!-- Tiêu đề -->
    <Label style="-fx-font-size:18px;                   -fx-font-weight:bold;                   -fx-text-fill:#0078D7;" text="💬 CHAT KHÁCH HÀNG" textFill="#0f0f59" />

    <!-- Người nhận -->
    <HBox alignment="CENTER_LEFT" spacing="10">

        <Label style="-fx-font-size:13px;                       -fx-font-weight:bold;" text="Gửi đến:" />

        <ComboBox fx:id="cbReceiver" prefWidth="260" promptText="-- Chọn khách hàng --">

            <HBox.hgrow>
                <Priority fx:constant="ALWAYS" />
            </HBox.hgrow>

        </ComboBox>

    </HBox>

    <!-- Khung chat -->
    <TextArea fx:id="txtChatHistory" editable="false" style="-fx-font-size:14px;                      -fx-control-inner-background:#f4f4f4;                      -fx-border-color:#dcdcdc;" wrapText="true" VBox.vgrow="ALWAYS" />

    <!-- Nhập tin -->
    <HBox spacing="10">

        <TextField fx:id="txtMessage" onAction="#handleSend" promptText="Nhập tin nhắn..." style="-fx-font-size:14px;">

            <HBox.hgrow>
                <Priority fx:constant="ALWAYS" />
            </HBox.hgrow>

        </TextField>

        <Button onAction="#handleSend" prefWidth="80" style="-fx-background-color:#0078D7;                        -fx-text-fill:white;                        -fx-font-weight:bold;" text="Gửi" />

    </HBox>

</VBox>
